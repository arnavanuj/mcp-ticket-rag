APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000

GITHUB_OWNER=langchain-ai
GITHUB_REPO=langchain
GITHUB_TOKEN=
GITHUB_PERSONAL_ACCESS_TOKEN=
GITHUB_API_BASE=https://api.github.com

# MCP-first settings
GITHUB_MCP_TRANSPORT=stdio
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/
# For stdio mode (optional)
GITHUB_MCP_SERVER_COMMAND=docker
GITHUB_MCP_SERVER_ARGS=run -i --rm -e GITHUB_PERSONAL_ACCESS_TOKEN -e GITHUB_TOOLSETS=issues,repos -e GITHUB_DYNAMIC_TOOLSETS=1 -e GITHUB_READ_ONLY=1 ghcr.io/github/github-mcp-server

MAX_ISSUES=20
MAX_OCR_IMAGES=10
RETRIEVAL_TOP_K=5
INCLUDE_COMMENTS=true
INCLUDE_REPO_DOCS=false

MISTRAL_ENDPOINT=http://localhost:11434
SEMANTIC_RESOLVER_MODEL=phi3:mini
SEMANTIC_RESOLVER_CONNECT_TIMEOUT_SECONDS=5
SEMANTIC_RESOLVER_FIRST_BYTE_TIMEOUT_SECONDS=20
SEMANTIC_RESOLVER_TIMEOUT_SECONDS=60
ANSWER_MODEL=mistral
ANSWER_CONNECT_TIMEOUT_SECONDS=5
ANSWER_FIRST_BYTE_TIMEOUT_SECONDS=45
ANSWER_TIMEOUT_SECONDS=240

PHI3_VISION_MODEL=llava-phi3
PHI3_FALLBACK_MODEL=phi3:latest
VISION_CONNECT_TIMEOUT_SECONDS=5
VISION_FIRST_BYTE_TIMEOUT_SECONDS=30
PHI3_TIMEOUT_SECONDS=120
OLLAMA_MAX_RETRIES=1
OLLAMA_ENABLE_WARMUP=false
OLLAMA_WARMUP_ON_START=false

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=16
EMBEDDING_LOCAL_FILES_ONLY=true
HF_CACHE_DIR=
